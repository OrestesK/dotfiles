#!/bin/sh
# Sync ThinkPad mute LED with PipeWire/PulseAudio mute state

LED=/sys/class/leds/platform::mute/brightness

sync_led() {
    pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | grep -q 'yes' && echo 1 | sudo tee "$LED" > /dev/null || echo 0 | sudo tee "$LED" > /dev/null
}

sync_led
pactl subscribe | while read -r line; do
    case "$line" in *sink*) sync_led ;; esac
done
