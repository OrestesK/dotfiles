# fixes acceleration
input type:touchpad {
    dwt disabled
    middle_emulation disabled
    accel_profile "flat"
    pointer_accel 1
}
input type:pointer {
    scroll_factor 2
}
# disables caps lock
input type:keyboard {
  xkb_options caps:none
  repeat_delay 250
  repeat_rate 40
}

include rules
include visual

set {
    $mod Mod4
    $alt Mod1
    $left h
    $down j
    $up k
    $right l
    $term foot
    $menu foot -a launcher -e env sway-launcher-desktop
    $trans 0.8
}
include appbinds

include startup

include swaybinds

bar {
	swaybar_command waybar
}
